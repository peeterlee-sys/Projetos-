# ─────────────────────────────────────────────────────────────
# Motor de Autoridade — variáveis de ambiente (SEM SEGREDOS AQUI)
# Copie para .env.local e preencha com valores reais. NUNCA commite .env.local.
# ─────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Motor de Autoridade"

# ── Supabase ──────────────────────────────────────────────────
# Painel: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Chave de service role — SOMENTE no servidor. Nunca exponha no cliente.
SUPABASE_SERVICE_ROLE_KEY=

# ── Provedores de IA (Fase 3+) ────────────────────────────────
# A camada de IA é abstrata; preencha o provedor que for usar.
AI_DEFAULT_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Teto mensal de custo de IA por tenant, em USD (0 ou vazio = sem limite).
AI_MONTHLY_COST_LIMIT_USD=

# ── Integração Make (Fase 3) ──────────────────────────────────
# Segredo compartilhado para assinar/verificar webhooks (HMAC).
MAKE_WEBHOOK_SECRET=

# ── Cron / jobs agendados (Fase 5) ────────────────────────────
CRON_SECRET=

# ── Web Push (Fase 5) ─────────────────────────────────────────
# Gere com: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contato@exemplo.com
