# ============================================================
# PORTA VOZ — configuração de ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# App
APP_NAME="PORTA VOZ"
DEBUG=false
ENVIRONMENT=production

# Database (SQLite para MVP, troque por PostgreSQL em produção)
DATABASE_URL=sqlite+aiosqlite:///./porta_voz.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/porta_voz

# OpenAI (Whisper para transcrição)
OPENAI_API_KEY=sk-...

# Anthropic (Claude para análise contextual)
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# Z-API (WhatsApp)
ZAPI_INSTANCE_ID=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ZAPI_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ZAPI_CLIENT_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ZAPI_BASE_URL=https://api.z-api.io

# Destinatários padrão dos alertas (separados por vírgula, formato: 5547999999999)
DEFAULT_ALERT_RECIPIENTS=5547999999999

# Monitoramento
CHUNK_DURATION_SECONDS=30
DEDUP_WINDOW_MINUTES=15
DEDUP_SIMILARITY_THRESHOLD=0.72
STREAM_RECONNECT_DELAY_SECONDS=10
MAX_RECONNECT_ATTEMPTS=10

# Roteamento por cidade contratada
# Abaixo desta confiança o alerta NÃO é enviado automaticamente (vai para revisão interna)
MIN_CITY_CONFIDENCE=0.75
# Chunks (atual + anteriores) enviados como bloco de contexto para a análise
ANALYSIS_CONTEXT_CHUNKS=3

# Áudio completo no WhatsApp
CLIP_PRE_CONTEXT_CHUNKS=2
CLIP_POST_CONTEXT_CHUNKS=2
MAX_AUDIO_MB=15
# URL pública do sistema — habilita o link "ouça o áudio completo" nos alertas
# PUBLIC_BASE_URL=https://radar.exemplo.com

# Redução de custo: não transcrever silêncio/sinal morto
SKIP_SILENT_CHUNKS=true
SILENCE_MEAN_DB_THRESHOLD=-45.0

# Avisos operacionais (rádio fora do ar, URL inválida...) — separados por vírgula
OPERATIONS_RECIPIENTS=5547999999999

# API
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=troque-por-uma-chave-secreta-longa-e-aleatoria

# Paths (não precisa alterar normalmente)
AUDIO_CHUNKS_DIR=audio_chunks
CLIPS_DIR=clips
LOGS_DIR=logs
