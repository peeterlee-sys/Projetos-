# ============================================================
# PORTA VOZ — configuração de ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# App
APP_NAME="PORTA VOZ"
DEBUG=false
ENVIRONMENT=production

# Database (SQLite para MVP, troque por PostgreSQL em produção)
DATABASE_URL=sqlite+aiosqlite:///./porta_voz.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/porta_voz

# OpenAI (Whisper para transcrição)
OPENAI_API_KEY=sk-...

# Anthropic (Claude para análise contextual)
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# Z-API (WhatsApp)
ZAPI_INSTANCE_ID=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ZAPI_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ZAPI_CLIENT_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ZAPI_BASE_URL=https://api.z-api.io

# Destinatários padrão dos alertas (separados por vírgula, formato: 5547999999999)
DEFAULT_ALERT_RECIPIENTS=5547999999999

# Monitoramento
CHUNK_DURATION_SECONDS=30
DEDUP_WINDOW_MINUTES=15
STREAM_RECONNECT_DELAY_SECONDS=10
MAX_RECONNECT_ATTEMPTS=10

# API
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=troque-por-uma-chave-secreta-longa-e-aleatoria

# Paths (não precisa alterar normalmente)
AUDIO_CHUNKS_DIR=audio_chunks
CLIPS_DIR=clips
LOGS_DIR=logs
