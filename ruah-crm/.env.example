# Banco de dados (libSQL/SQLite local por padrao; aponte para o Turso em producao)
DATABASE_URL=file:./ruah-crm.db
DATABASE_AUTH_TOKEN=

# Protege os endpoints de cron e o webhook do WhatsApp
CRON_SECRET=troque-este-valor
WHATSAPP_WEBHOOK_VERIFY_TOKEN=troque-este-valor

# WhatsApp Cloud API (Meta) - https://developers.facebook.com/docs/whatsapp/cloud-api
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Numeros (com DDI) que devem receber os alertas de lembrete via WhatsApp, separados por virgula
WHATSAPP_ALERT_RECIPIENTS=

# E-mail (SMTP) para alertas de lembrete
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Ruah CRM <crm@ruah.com.br>"
# Destinatarios que recebem os alertas por e-mail, separados por virgula
EMAIL_ALERT_RECIPIENTS=
